# ============================================================
# .env.example
#
# PURPOSE: Template for all environment variables the project needs.
#
# HOW TO USE:
#   1. Copy this file:   cp .env.example .env
#   2. Fill in your real values in .env
#   3. NEVER commit .env to git (it contains secrets!)
#
# BEGINNER CONCEPT — What are environment variables?
# Environment variables are values set OUTSIDE your code.
# Instead of writing your API key directly in the code:
#     client = OpenAI(api_key="sk-abc123")   ← DANGEROUS (goes into git!)
# You reference an environment variable:
#     client = OpenAI(api_key=os.environ["OPENAI_API_KEY"])   ← SAFE
#
# The actual value lives only in .env (which is gitignored).
# Your team members each have their own .env with their own keys.
#
# WHY .env.example?
# You CAN commit .env.example — it shows what variables are needed
# without exposing any real values. It's the "blank form" version.
# ============================================================


# ── LLM API Keys ──────────────────────────────────────────────

# Mistral API key — for ALL chat (answers, summaries, judges, agents)
# Free tier available at: https://console.mistral.ai/
MISTRAL_API_KEY=your-mistral-key-here

# Which Mistral model to use
# mistral-large-latest  → best quality (like GPT-4o)
# mistral-small-latest  → faster, cheaper
MISTRAL_MODEL=mistral-large-latest

# OpenAI API key — OPTIONAL. Only needed if you want to use GPT-4o for chat instead of Mistral.
# Embeddings now use HuggingFace locally — OpenAI is NOT needed for embeddings.
# OPENAI_API_KEY=sk-your-openai-key-here

# ── Embeddings (FREE — no API key needed) ─────────────────────
# HuggingFace BAAI/bge model runs locally on your computer.
# Change this to use a different model (see config/settings.yaml for options).
HF_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5


# ── Database Credentials ──────────────────────────────────────

# PostgreSQL password for the 'raguser' database user
# Choose a strong password in production!
DB_PASSWORD=ragpassword_change_me_in_production

# Full PostgreSQL connection URL (built from the values above)
# Format: postgresql://username:password@host:port/database_name
# When using docker-compose, host = service name ("postgres")
DATABASE_URL=postgresql://raguser:ragpassword_change_me_in_production@localhost:5432/ragdb


# ── API Security ──────────────────────────────────────────────

# Secret key for API authentication
# All API requests must include header: X-API-Key: <this value>
# Use a long random string in production:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
API_SECRET_KEY=api_secret_key_change_me_in_production

# Comma-separated list of valid API keys (for multiple clients)
# VALID_API_KEYS=key1,key2,key3


# ── Vector Database (Qdrant) ──────────────────────────────────

# When running locally (not in Docker):
QDRANT_HOST=localhost
QDRANT_PORT=6333

# Name of the Qdrant collection where chunks are stored
QDRANT_COLLECTION_NAME=rag_chunks


# ── Optional: Web Search Tool ─────────────────────────────────

# Serper API key for web search fallback
# Free tier available at: https://serper.dev/
SERPER_API_KEY=your-serper-api-key-here


# ── Optional: Redis Cache ─────────────────────────────────────

# Redis connection URL (used for distributed rate limiting)
# Only needed if running multiple API instances
REDIS_URL=redis://localhost:6379


# ── Application Settings ──────────────────────────────────────

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Set to "development" or "production"
# Development: verbose errors, auto-reload
# Production: minimal errors shown to users
ENVIRONMENT=development

# Maximum file size for uploads (in megabytes)
MAX_UPLOAD_SIZE_MB=50


# ── RAG Pipeline Tuning ───────────────────────────────────────

# How many chunks to retrieve per query (higher = more context, slower)
DEFAULT_TOP_K=5

# Minimum similarity score to include a chunk (0.0 to 1.0)
# Higher = stricter filtering (fewer but more relevant chunks)
MIN_SIMILARITY_SCORE=0.0

# Evaluation score threshold — below this triggers feedback loop
EVAL_THRESHOLD=7.0
