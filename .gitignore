# ============================================================
# .gitignore
#
# PURPOSE: Tell Git which files to NEVER track or commit.
#
# BEGINNER CONCEPT — Why do we need .gitignore?
# Git tracks ALL files by default. But some files should NEVER
# be in version control:
#
# ❌ .env         → Contains your real API keys (SECRETS!)
# ❌ __pycache__/ → Python bytecode (auto-generated, not source)
# ❌ venv/        → Virtual environment (huge, reproducible from requirements.txt)
# ❌ *.log        → Log files (runtime data, not source code)
# ❌ qdrant_data/ → Database files (too large, not source code)
#
# If you accidentally commit a secret, change it IMMEDIATELY
# (even deleted files stay in git history forever).
# ============================================================

# ── SECRETS (NEVER commit these!) ────────────────────────────
.env
.env.local
.env.production
*.key
*.pem
secrets/

# ── Python Bytecode ───────────────────────────────────────────
__pycache__/
*.py[cod]           # .pyc, .pyo, .pyd compiled files
*$py.class
*.so                # Compiled C extensions

# ── Virtual Environments ──────────────────────────────────────
venv/
env/
.venv/
.env/
ENV/
env.bak/

# ── Python Distribution / Build ───────────────────────────────
dist/
build/
*.egg-info/
*.egg
wheels/
*.whl

# ── Testing & Coverage ────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
coverage.xml
*.cover
.hypothesis/
junit.xml

# ── IDEs & Editors ────────────────────────────────────────────
.idea/              # PyCharm
.vscode/            # VS Code (team members may have different settings)
*.swp               # Vim swap files
*.swo
.DS_Store           # macOS folder metadata
Thumbs.db           # Windows thumbnail cache
*.sublime-project
*.sublime-workspace

# ── Jupyter Notebooks ─────────────────────────────────────────
# Keep .ipynb files but ignore their outputs and checkpoints
.ipynb_checkpoints/
notebooks/.ipynb_checkpoints/

# ── Logs ──────────────────────────────────────────────────────
*.log
logs/
log/

# ── Docker Data Volumes ───────────────────────────────────────
# These are mounted as volumes in docker-compose
postgres_data/
qdrant_data/
redis_data/

# ── Uploaded Files ────────────────────────────────────────────
# User-uploaded documents should not go into git
uploads/
/tmp/rag_uploads/

# ── Generated Files ───────────────────────────────────────────
stress_test_report*.json
eval_report*.json

# ── OS Files ──────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ── Type Checking ─────────────────────────────────────────────
.mypy_cache/
.dmypy.json
dmypy.json
.pytype/
